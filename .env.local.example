# Copy this to `.env.local` and fill in the values.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Resend — https://resend.com/api-keys (used to email new contact-form
# submissions to the studio inbox). Without this var set, the form still
# saves to Supabase but no notification email is sent.
RESEND_API_KEY=re_your-key-here
